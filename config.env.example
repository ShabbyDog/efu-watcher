# efu-watcher configuration
# Copy to /etc/efu-watcher/config.env and adjust for your environment.
# Any variable set here overrides the default baked into the systemd unit file.

# Absolute path to the directory to watch. Must be a mountpoint or a directory
# within one. The daemon will wait and retry if it is not available on startup.
WATCH_ROOT=/mnt/nas/share

# Path where the EFU file will be written. Point Everything's File Lists at
# this path using its UNC equivalent (e.g. \\server\share\.everything_index.efu).
# This file is excluded from the index automatically.
EFU_PATH=/mnt/nas/share/.everything_index.efu

# Path to the SQLite database that stores the file index.
# The directory must exist and be writable by the service user.
DB_PATH=/var/lib/efu-watcher/index.db

# Hostname used in Windows UNC paths written to the EFU file.
# This should be the name Windows uses to reach the server (hostname or IP).
# Example UNC path produced: \\myserver.local\share\folder\file.txt
UNC_HOST=myserver.local

# Share name used in Windows UNC paths. Corresponds to the top-level share
# name as seen from Windows, not the Linux mount path.
UNC_SHARE=share

# Seconds to wait after the last filesystem event before flushing changes to
# the EFU file. Higher values reduce I/O on busy directories at the cost of
# slightly stale results. Recommended range: 1.0–10.0.
DEBOUNCE_WINDOW=3.0

# Hour of the day (0–23, local time) at which to perform a full consistency
# rebuild of the EFU file from the database. Pick a quiet period.
# The rebuild is also triggered automatically if an in-place patch fails.
DAILY_REBUILD_HOUR=3

# EFU files larger than this threshold (in MB) will trigger a full rebuild
# instead of an in-place patch, to avoid loading very large files into memory.
MAX_PATCH_SIZE_MB=200

# Python logging level. One of: DEBUG, INFO, WARNING, ERROR.
# Use DEBUG to log every individual filesystem event (very verbose on busy shares).
LOG_LEVEL=INFO
